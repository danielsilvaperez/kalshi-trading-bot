# ============================================================
# Kalshi Trading Bot — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your .env file.
# ============================================================

# ------------------------------------------------------------
# Kalshi API credentials (required — use RSA key auth)
# ------------------------------------------------------------
KALSHI_KEY_ID=your-kalshi-api-key-id
# Paste the full PEM content on one line with \n for newlines, e.g.:
# KALSHI_PRIVATE_KEY_PEM=-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----
KALSHI_PRIVATE_KEY_PEM=

# Optional: legacy bearer token (not recommended for live trading)
# KALSHI_TOKEN=

# Kalshi API base URL (defaults to production)
# KALSHI_BASE_URL=https://api.elections.kalshi.com

# ------------------------------------------------------------
# Telegram notifications (optional)
# ------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ------------------------------------------------------------
# Trading configuration
# ------------------------------------------------------------
# Set to false to place real orders (default: dry-run)
DRY_RUN=true

# Set to true to allow live order execution
ALLOW_LIVE=false

# Capital & risk limits
START_CAPITAL_USD=8
MAX_DAILY_LOSS_USD=2
MAX_NOTIONAL_PER_TRADE_USD=2
MAX_OPEN_POSITIONS=2
MAX_SPEND_CENTS=200

# Fees & slippage (in cents)
FEE_PER_CONTRACT_CENTS=0.2
SLIPPAGE_CENTS=0.25

# Timing
POLL_MS=300000
MIN_SECONDS_TO_EXPIRY=120

# Kill switch
KILL_SWITCH=false
KILL_BALANCE_CENTS=500

# Circuit breaker
CIRCUIT_BREAKER_THRESHOLD=3
MAX_CONSECUTIVE_LOSSES=3

# ------------------------------------------------------------
# Market selection
# ------------------------------------------------------------
# Specific ticker to trade (optional; auto-discover used if unset)
# KALSHI_TICKER=KXBTC15M-26FEB140845-45
AUTO_DISCOVER_TICKER=true

# Enable strategies
ENABLE_ARB=true
ENABLE_DIRECTIONAL=true

# Run once and exit
ONCE=false

# ------------------------------------------------------------
# File paths (optional — defaults shown)
# ------------------------------------------------------------
# JOURNAL_PATH=./logs/trading-journal.jsonl
# LOCK_PATH=./tmp/trading-run.lock
# LOG_PATH=./logs/trading-15m.jsonl
# OUTCOMES_PATH=./logs/outcomes.jsonl
# ADAPTIVE_CONFIG_PATH=./config/adaptive.json
# STATE_PATH=./tmp/state.json

# ------------------------------------------------------------
# Optional third-party data API keys
# ------------------------------------------------------------
# COINAPI_KEY=
# GLASSNODE_API_KEY=
# OPENWEATHER_API_KEY=
